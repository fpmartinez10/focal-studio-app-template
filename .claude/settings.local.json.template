{
  "_comment": [
    "This template is for PERSONAL machine-specific overrides only.",
    "",
    "The shared project permissions (git, npm, expo, gh, shell utils, WebFetch to dev domains)",
    "are already in .claude/settings.json (tracked). You do NOT need to repeat them here.",
    "",
    "Copy this file to .claude/settings.local.json (gitignored) and uncomment the entries you want.",
    "",
    "Common additions:",
    "  - Custom Homebrew path if your brew is not at /opt/homebrew/bin/",
    "  - Allow brew/pip/npm -g autonomously IF you trust devops-agent to run them after its risk report",
    "    (by default these prompt the user — which is the safe behaviour)"
  ],
  "permissions": {
    "allow": [
      "__UNCOMMENT_IF_NEEDED__: Bash(/usr/local/bin/gh pr:*)",
      "__UNCOMMENT_IF_NEEDED__: Bash(/usr/local/bin/gh issue:*)",
      "__UNCOMMENT_IF_NEEDED__: Bash(/usr/local/bin/gh repo:*)",
      "__UNCOMMENT_IF_NEEDED__: Bash(/usr/local/bin/gh api:*)",
      "__UNCOMMENT_IF_NEEDED__: Bash(/usr/local/bin/gh auth:*)",
      "__UNCOMMENT_IF_NEEDED__: Bash(/usr/local/bin/gh label:*)",

      "__ devops-agent autonomous installs (remove leading __ to enable) __",
      "__: Bash(brew install:*)",
      "__: Bash(brew upgrade:*)",
      "__: Bash(brew list:*)",
      "__: Bash(/opt/homebrew/bin/brew install:*)",
      "__: Bash(/opt/homebrew/bin/brew upgrade:*)",
      "__: Bash(npm install -g:*)",
      "__: Bash(npm install --global:*)",
      "__: Bash(pip install:*)",
      "__: Bash(pip3 install:*)"
    ]
  }
}